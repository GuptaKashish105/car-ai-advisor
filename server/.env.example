# Port the server listens on. Render/Railway set this automatically in
# production — the app reads process.env.PORT with this as a local fallback.
PORT=3001

# Required for AI-generated match explanations. Without it, the API still
# returns full, correctly-scored recommendations — aiExplanation is just
# null on every result (see server/src/services/geminiService.ts).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Overrides the default Gemini model (gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Optional. Comma-separated list of allowed frontend origins, e.g.
#   CORS_ORIGIN=https://car-ai-advisor.vercel.app
# Leave unset for local development (allows any origin). Set this in
# production to the deployed Vercel URL so the API only accepts requests
# from your own frontend.
# CORS_ORIGIN=https://your-frontend.vercel.app
