# Base URL the client sends API requests to.
#
# Local development: leave unset. Vite's dev server proxies "/api" to the
# local Express server (see vite.config.ts) — no configuration needed.
#
# Production (Vercel): REQUIRED. Set to your deployed backend's URL,
# including the "/api" prefix the Express server mounts its routes under:
#   VITE_API_BASE_URL=https://your-backend.onrender.com/api
#
# Vite only reads env vars at build time, so this must be set in Vercel's
# project settings (not just committed here) before building for production.
VITE_API_BASE_URL=/api
